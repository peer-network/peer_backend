{
  "compilerOptions": {
    "rootDirs": ["src"],
    "outDir": "dist",
    "lib": ["es2020"],
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["node"],
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,
    "paths": {
      "*": ["node_modules/*"]
    },
    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types"],
    "strict": true,
    "resolveJsonModule": true,
  }
}
